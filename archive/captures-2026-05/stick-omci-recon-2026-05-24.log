=== $ cat /etc/init.d/rcS ===
#!/bin/sh

echo === Start to run rc0 ~ rc63 ===
i=0
while [ "$i" != "64" ]
do
	rc_file=/etc/init.d/rc$i
	if [ -f "$rc_file" ]; then 
		echo "----- do_rc [$rc_file] -----"	
		sh $rc_file
	fi	
	i=$(($i+1))
done
# 

